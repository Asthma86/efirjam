  m_GameObject: {fileID: 303799065}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae71939d3ba21044abbd9876035cc25c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SignalGenerator
  timeManager: {fileID: 303799067}
  infoTextUI: {fileID: 1177420205}
  messageTextUI: {fileID: 2067989451}
  signalTemplates:
  - Sender: "\u042D\u043A\u0441\u0442\u0440\u0435\u043D\u043D\u0430\u044F \u0441\u043B\u0443\u0436\u0431\u0430 "
    Receiver: "\u0411\u043E\u043B\u044C\u043D\u0438\u0446\u0430 \u21162 "
    MessageText: "\u041C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
      \u0442\u0440\u0430\u0432\u043C\u044B \u043F\u0440\u0438 \u043E\u0431\u0440\u0443\u0448\u0435\u043D\u0438\u0438
      \u043B\u0435\u0441\u043E\u0432 \u043D\u0430 \u0441\u0442\u0440\u043E\u0439\u043A\u0435.
      \u0422\u0440\u043E\u0435 \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u0432\u0448\u0438\u0445.
      \u0413\u043E\u0442\u043E\u0432\u044C\u0442\u0435 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u0443\u044E
      \u0438 \u0445\u0438\u0440\u0443\u0440\u0433\u0430. \u0411\u0443\u0434\u0435\u043C
      \u0447\u0435\u0440\u0435\u0437 20 \u043C\u0438\u043D\u0443\u0442."
  - Sender: "\u042D\u043A\u0441\u0442\u0440\u0435\u043D\u043D\u0430\u044F \u0441\u043B\u0443\u0436\u0431\u0430 "
    Receiver: "\u0421\u043F\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
      \u043E\u0442\u0440\u044F\u0434  "
    MessageText: "\u041F\u043E\u0442\u0435\u0440\u044F\u043B\u0441\u044F \u0440\u0435\u0431\u0451\u043D\u043E\u043A
      \u0432 \u043B\u0435\u0441\u043D\u043E\u043C \u043C\u0430\u0441\u0441\u0438\u0432\u0435
      \u0443 \u0434\u0435\u0440\u0435\u0432\u043D\u0438 \u041A\u043B\u044E\u0447\u0438.
      \u041C\u0430\u043B\u044C\u0447\u0438\u043A 7 \u043B\u0435\u0442, \u043A\u0440\u0430\u0441\u043D\u0430\u044F
      \u043A\u0443\u0440\u0442\u043A\u0430. \u041D\u0430\u0447\u0438\u043D\u0430\u0439\u0442\u0435
      \u043F\u0440\u043E\u0447\u0451\u0441\u044B\u0432\u0430\u043D\u0438\u0435 \u0441
      \u0441\u0435\u0432\u0435\u0440\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B."
  - Sender: "\u042D\u043A\u0441\u0442\u0440\u0435\u043D\u043D\u0430\u044F \u0441\u043B\u0443\u0436\u0431\u0430 "
    Receiver: "\u041F\u043E\u0436\u0430\u0440\u043D\u0430\u044F \u0447\u0430\u0441\u0442\u044C   "
    MessageText: "\u0412\u043E\u0437\u0433\u043E\u0440\u0430\u043D\u0438\u0435 \u043D\u0430
      \u0441\u043A\u043B\u0430\u0434\u0435 \u0433\u043E\u0440\u044E\u0447\u0435-\u0441\u043C\u0430\u0437\u043E\u0447\u043D\u044B\u0445
      \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432. \u0423\u043B\u0438\u0446\u0430
      \u041F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u0430\u044F, 7.
      \u0422\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F \u0442\u0440\u0438 \u0440\u0430\u0441\u0447\u0451\u0442\u0430
      \u0438 \u043F\u0435\u043D\u043D\u044B\u0439 \u0430\u0432\u0442\u043E\u043C\u043E\u0431\u0438\u043B\u044C."
  - Sender: "\u042D\u043A\u0441\u0442\u0440\u0435\u043D\u043D\u0430\u044F \u0441\u043B\u0443\u0436\u0431\u0430 "
    Receiver: "\u041C\u0438\u043B\u0438\u0446\u0438\u044F  "
    MessageText: "\u041C\u0430\u0441\u0441\u043E\u0432\u0430\u044F \u0434\u0440\u0430\u043A\u0430
      \u0432 \u0440\u0430\u0439\u043E\u043D\u0435 \u0440\u044B\u043D\u043A\u0430.
      \u0415\u0441\u0442\u044C \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u0432\u0448\u0438\u0435.
      \u041D\u0443\u0436\u0435\u043D \u043D\u0430\u0440\u044F\u0434 \u0434\u043B\u044F
      \u043E\u0446\u0435\u043F\u043B\u0435\u043D\u0438\u044F \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438."
  - Sender: "\u0421\u043A\u043E\u0440\u0430\u044F-03  "
    Receiver: "\u042D\u043A\u0441\u0442\u0440\u0435\u043D\u043D\u0430\u044F \u0441\u043B\u0443\u0436\u0431\u0430  "
    MessageText: "\u0416\u0435\u043D\u0449\u0438\u043D\u0430 \u0441 \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u043D\u0438\u0435\u043C
      \u043D\u0430 \u0430\u043F\u043F\u0435\u043D\u0434\u0438\u0446\u0438\u0442 \u0434\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
      \u0432 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u0443. \u0421\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
      \u0441\u0440\u0435\u0434\u043D\u0435\u0439 \u0442\u044F\u0436\u0435\u0441\u0442\u0438.
      \u041E\u0436\u0438\u0434\u0430\u0435\u043C \u0440\u0435\u0448\u0435\u043D\u0438\u044F
      \u0445\u0438\u0440\u0443\u0440\u0433\u0430."
